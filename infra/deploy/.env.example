# ---------------------------------------------------------------------------
# Stack configuration — copy to .env and fill in values
# ---------------------------------------------------------------------------

# Stack names
STACK_NAME=www
DB_STACK_NAME=www-db

# Image tag (CI build tag in production, e.g. 2025.14.0; use "local" for test builds)
IMAGE_TAG=master

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
MYSQL_DATABASE=www-cms
MYSQL_USER=drupal
DRUPAL_DATABASE_HOST=www-db_mariadb
DRUPAL_DATABASE_DB_NAME=www-cms
DRUPAL_DATABASE_USERNAME=drupal

# ---------------------------------------------------------------------------
# AWS EFS (required in production; leave blank for local Docker volume testing)
# ---------------------------------------------------------------------------
# DNS name of EFS filesystem, e.g. fs-0123456789abcdef0.efs.us-east-1.amazonaws.com
EFS_FILES_DNS=
EFS_SYNC_DNS=

# ---------------------------------------------------------------------------
# External service hosts
# ---------------------------------------------------------------------------
LEGACY_CMS_HOST=archive.cbd.int
LEGACY_CMS_PORT=443
LEGACY_WWW_FALLBACK_URL=https://archive.cbd.int
API_HOST=api.cbd.int
API_PORT=443
GAIA_S3_ENDPOINT=s3.us-east-1.amazonaws.com

# ---------------------------------------------------------------------------
# Nuxt application
# ---------------------------------------------------------------------------
NUXT_ORT_URL=https://ort.cbd.int
